---
const currentPath = Astro.url.pathname;
const links = [
  { href: '/', label: 'Home' },
  { href: '/science', label: 'Science' },
  { href: '/music', label: 'Music' },
  { href: '/writing', label: 'Writing' },
];
---

<nav class="nav" transition:persist>
  <div class="container nav-inner">
    <a href="/" class="nav-logo">tkafka</a>
    <div class="nav-links">
      {links.map((link) => (
        <a
          href={link.href}
          data-href={link.href}
          class:list={{ 'nav-link': true, active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  function updateActive() {
    const path = window.location.pathname;
    document.querySelectorAll('.nav-link').forEach((el) => {
      const href = el.getAttribute('data-href') ?? '';
      const isActive = path === href || (href !== '/' && path.startsWith(href));
      el.classList.toggle('active', isActive);
    });
  }
  document.addEventListener('astro:page-load', updateActive);
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    background: #c0c0c0;
    border-bottom: 2px solid #808080;
    box-shadow: inset 0 -1px 0 #000;
    z-index: 100;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-logo {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-sm);
    font-weight: 700;
    color: #000;
    padding: 3px 8px;
  }

  .nav-logo:hover {
    color: #000;
  }

  .nav-links {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .nav-link {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-sm);
    font-weight: 400;
    color: #000;
    padding: 3px 10px;
    background: #c0c0c0;
    transition: none;
    line-height: 1.4;
  }

  .nav-link:hover {
    color: #000;
    box-shadow:
      inset 1px 1px 0 #fff,
      inset -1px -1px 0 #000,
      inset 2px 2px 0 #dfdfdf,
      inset -2px -2px 0 #808080;
  }

  .nav-link.active {
    color: #000;
    box-shadow:
      inset -1px -1px 0 #fff,
      inset 1px 1px 0 #808080,
      inset -2px -2px 0 #dfdfdf,
      inset 2px 2px 0 #000;
    padding: 4px 9px 2px 11px;
  }
</style>
