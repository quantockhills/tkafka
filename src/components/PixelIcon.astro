---
export interface Props {
  name: 'science' | 'music' | 'art';
  size?: number;
}

const { name, size = 32 } = Astro.props;
---

{
  name === 'science' && (
    <svg width={size} height={size} viewBox="0 0 16 16" class="pixel-icon" aria-hidden="true">
      <rect x="3" y="1" width="10" height="2" fill="currentColor" />
      <rect x="3" y="3" width="2" height="4" fill="currentColor" />
      <rect x="11" y="3" width="2" height="4" fill="currentColor" />
      <rect x="7" y="5" width="2" height="2" fill="currentColor" />
      <rect x="5" y="7" width="6" height="2" fill="currentColor" />
      <rect x="1" y="9" width="14" height="2" fill="currentColor" />
      <rect x="1" y="11" width="2" height="4" fill="currentColor" />
      <rect x="13" y="11" width="2" height="4" fill="currentColor" />
      <rect x="3" y="13" width="10" height="2" fill="currentColor" />
    </svg>
  )
}

{
  name === 'music' && (
    <svg width={size} height={size} viewBox="0 0 16 16" class="pixel-icon" aria-hidden="true">
      <rect x="4" y="0" width="2" height="12" fill="currentColor" />
      <rect x="6" y="0" width="6" height="2" fill="currentColor" />
      <rect x="6" y="2" width="2" height="4" fill="currentColor" />
      <rect x="4" y="12" width="4" height="2" fill="currentColor" />
      <rect x="4" y="14" width="2" height="2" fill="currentColor" />
      <rect x="6" y="14" width="2" height="2" fill="currentColor" />
      <rect x="10" y="10" width="4" height="2" fill="currentColor" />
      <rect x="10" y="12" width="2" height="2" fill="currentColor" />
      <rect x="12" y="12" width="2" height="2" fill="currentColor" />
    </svg>
  )
}

{
  name === 'art' && (
    <svg width={size} height={size} viewBox="0 0 16 16" class="pixel-icon" aria-hidden="true">
      <rect x="1" y="1" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1" />
      <rect x="3" y="3" width="4" height="4" fill="currentColor" />
      <rect x="9" y="3" width="4" height="4" fill="currentColor" />
      <rect x="3" y="9" width="4" height="4" fill="currentColor" />
      <rect x="9" y="9" width="4" height="2" fill="currentColor" />
      <rect x="9" y="13" width="4" height="2" fill="currentColor" />
      <rect x="9" y="11" width="2" height="2" fill="currentColor" />
      <rect x="13" y="11" width="2" height="2" fill="currentColor" />
    </svg>
  )
}

<style>
  .pixel-icon {
    image-rendering: pixelated;
    display: block;
  }
</style>
