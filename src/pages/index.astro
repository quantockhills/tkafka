---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="tkafka — Madhav Mohan" wide={true}>
  <div class="hero">
    <img src="/front.jpeg" alt="" class="hero-img" />
    <div class="hero-text">
      <h1 class="hero-name">Madhav Mohan</h1>
      <p class="hero-tagline">quantum physicist · musician · writer</p>
    </div>
  </div>

  <div class="container sections-container">
    <section class="sections">
      <a href="/science" class="section-link">
        <span class="section-label">Science</span>
        <span class="section-desc">quantum computing, research, tech</span>
      </a>
      <a href="/music" class="section-link">
        <span class="section-label">Music</span>
        <span class="section-desc">band, recordings, writing</span>
      </a>
      <a href="/writing" class="section-link">
        <span class="section-label">Writing</span>
        <span class="section-desc">essays, notes, words</span>
      </a>
    </section>
  </div>

  <div class="closing">
    <img src="/back.jpeg" alt="" class="closing-img" />
  </div>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-top: var(--nav-height);
  }

  .hero-img {
    width: 100%;
    height: calc(100vh - var(--nav-height));
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .hero-text {
    position: absolute;
    bottom: var(--space-12);
    left: var(--space-8);
    color: rgba(250, 250, 249, 0.92);
  }

  .hero-name {
    font-size: var(--text-5xl);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .hero-tagline {
    font-size: var(--text-base);
    font-weight: 300;
    letter-spacing: 0.01em;
    opacity: 0.75;
  }

  .sections-container {
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .section-link {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: 5px 10px;
    background: #c0c0c0;
    box-shadow:
      inset 1px 1px 0 #fff,
      inset -1px -1px 0 #000,
      inset 2px 2px 0 #dfdfdf,
      inset -2px -2px 0 #808080;
    transition: none;
  }

  .section-link:hover {
    box-shadow:
      inset -1px -1px 0 #fff,
      inset 1px 1px 0 #808080,
      inset -2px -2px 0 #dfdfdf,
      inset 2px 2px 0 #000;
    padding: 6px 9px 4px 11px;
  }

  .section-label {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-base);
    font-weight: 700;
    color: #000;
    min-width: 80px;
  }

  .section-desc {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-sm);
    font-weight: 400;
    color: #444;
  }

  .closing-img {
    width: 100%;
    max-height: 80vh;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: var(--text-4xl);
    }

    .hero-text {
      left: var(--space-4);
      bottom: var(--space-8);
    }

    .section-link {
      flex-direction: column;
      gap: var(--space-1);
    }
  }
</style>
