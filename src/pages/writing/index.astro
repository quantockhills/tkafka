---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('writing');
const folders = [...new Set(posts.map(p => p.data.folder).filter(Boolean))];
---

<BaseLayout title="Writing — tkafka">
  <section class="section-header">
    <h1 class="section-title">Writing</h1>
    <p class="section-subtitle">essays, notes, words</p>
  </section>

  <section class="folder-grid">
    {folders.map((folder) => (
      <a href={`/writing/${folder}`} class="folder-item">
        <div class="folder-icon">
          <img src="/images/folder.png" alt="" width="64" height="59" />
        </div>
        <span class="folder-label">{folder}</span>
      </a>
    ))}

    {folders.length === 0 && <p class="empty">No writing projects yet.</p>}
  </section>
</BaseLayout>

<style>
  .section-header {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .folder-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    padding: var(--space-8) 0;
  }

  .folder-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    width: 100px;
    padding: var(--space-3);
    text-decoration: none;
    color: var(--color-text);
    cursor: pointer;
    border: 1px solid transparent;
  }

  .folder-item:hover {
    background: rgba(0, 0, 128, 0.08);
    border-color: rgba(0, 0, 128, 0.2);
  }

  .folder-icon {
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .folder-label {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-sm);
    text-align: center;
    word-break: break-all;
    line-height: 1.2;
    color: var(--color-text);
  }

  .empty {
    color: var(--color-text-muted);
    font-weight: 300;
  }
</style>
