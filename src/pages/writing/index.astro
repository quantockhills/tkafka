---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = await getCollection('writing');
const folders = [...new Set(posts.map(p => p.data.folder).filter(Boolean))];
---

<BaseLayout title="Writing — tkafka">
  <section class="section-header">
    <h1 class="section-title">Writing</h1>
    <p class="section-subtitle">essays, notes, words</p>
  </section>

  <section class="folder-grid">
    {folders.map((folder) => (
      <a href={`/writing/${folder}`} class="folder-item">
        <div class="folder-icon">
          <img src="/images/folder.png" alt="" width="96" height="89" />
        </div>
        <span class="folder-label">{folder}</span>
      </a>
    ))}

    {folders.length === 0 && <p class="empty">No writing projects yet.</p>}
  </section>

  <section class="folder-info">
    <p>As a 19 year old student at the University of Delhi, having discovered the wondrous world of surrealist literature and indie music, I created a blog to write articles on my favorite albums and books. This grew to a collective effort, with my friends contributing articles as well. The blog closed in 2023 as my focus shifted to writing songs, but I have collected my favorite articles here. It is not permanently closed and I will be exploring creative ways to revive it. Perhaps in the form of an art collective, inspired by the DIY film clubs of the French New Wave.</p>
  </section>
</BaseLayout>

<style>
  .section-header {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--space-8);
  }

  .folder-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-8);
    padding: var(--space-8) 0;
  }

  .folder-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    width: 140px;
    padding: var(--space-3);
    text-decoration: none;
    color: var(--color-text);
    cursor: pointer;
    border: 1px solid transparent;
  }

  .folder-item:hover {
    background: rgba(0, 0, 128, 0.08);
    border-color: rgba(0, 0, 128, 0.2);
  }

  .folder-icon {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .folder-label {
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-base);
    text-align: center;
    white-space: nowrap;
    line-height: 1.2;
    color: var(--color-text);
  }

  .folder-info {
    max-width: 600px;
    margin: var(--space-12) auto;
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .folder-info p {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .empty {
    color: var(--color-text-muted);
    font-weight: 300;
  }
</style>
