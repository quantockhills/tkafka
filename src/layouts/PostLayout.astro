---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  collection: string;
  bgImage?: string;
}

const { title, date, description, tags, collection, bgImage } = Astro.props;
const backHref = `/${collection}`;
---

<BaseLayout title={`${title} — tkafka`} bgImage={bgImage}>
  <article class="post">
    <a href={backHref} class="post-back">&larr; {collection}</a>
    <header class="post-header">
      <h1 class="post-title">{title}</h1>
      {description && <p class="post-description">{description}</p>}
      <div class="post-meta">
        <time datetime={date.toISOString()}>{date.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
        {tags && tags.length > 0 && (
          <div class="post-tags">
            {tags.map((tag) => <span class="post-tag">{tag}</span>)}
          </div>
        )}
      </div>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .post-back {
    display: inline-block;
    font-family: "Tahoma", "MS Sans Serif", Arial, sans-serif;
    font-size: var(--text-sm);
    font-weight: 400;
    color: #000;
    background: #c0c0c0;
    padding: 3px 10px;
    margin-bottom: var(--space-6);
    box-shadow:
      inset 1px 1px 0 #fff,
      inset -1px -1px 0 #000,
      inset 2px 2px 0 #dfdfdf,
      inset -2px -2px 0 #808080;
    transition: none;
  }

  .post-back:hover {
    color: #000;
    box-shadow:
      inset -1px -1px 0 #fff,
      inset 1px 1px 0 #808080,
      inset -2px -2px 0 #dfdfdf,
      inset 2px 2px 0 #000;
    padding: 4px 9px 2px 11px;
  }

  .post-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-size: var(--text-3xl);
    font-weight: 300;
    letter-spacing: -0.01em;
    margin-bottom: var(--space-4);
  }

  .post-description {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-muted);
    font-style: italic;
    margin-bottom: var(--space-4);
    margin-top: 0;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
  }

  .post-tags {
    display: flex;
    gap: var(--space-2);
  }

  .post-tag {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .post-tag:not(:last-child)::after {
    content: ',';
  }

  .post-content {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
  }

  .post-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: 400;
    margin-top: var(--space-16);
    margin-bottom: 2rem;
  }

  .post-content :global(h3) {
    font-size: var(--text-lg);
    font-weight: 400;
    margin-top: var(--space-12);
    margin-bottom: 1.5rem;
  }

  .post-content :global(p) {
    margin-bottom: var(--space-8);
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .post-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .post-content :global(strong) {
    font-weight: 400;
    color: var(--color-text);
  }

  .post-content :global(a) {
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
  }

  .post-content :global(a:hover) {
    color: var(--color-text-muted);
    border-bottom-color: var(--color-text-muted);
  }

  .post-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-12) 0;
  }

  .post-content :global(blockquote) {
    border-left: 1px solid var(--color-text);
    padding-left: var(--space-6);
    margin-left: 0;
    margin-top: var(--space-8);
    margin-bottom: var(--space-12);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-content :global(img) {
    width: 100%;
    height: auto;
    margin: var(--space-16) 0;
  }

  .post-content :global(img:first-child) {
    margin-top: var(--space-8);
  }

  .post-content :global(code) {
    font-size: var(--text-sm);
    background: rgba(0,0,0,0.04);
    padding: 1px 4px;
    border-radius: 2px;
  }

  .post-content pre {
    background: rgba(0,0,0,0.04);
    padding: var(--space-4);
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }

  .post-content pre code {
    background: none;
    padding: 0;
  }
</style>
